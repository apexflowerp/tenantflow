generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  industry    String?
  currency    String   @default("USD")
  timezone    String   @default("UTC")
  plan        String   @default("starter")
  clientId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  properties  Property[]
  tenants     Tenant[]
  leases      Lease[]
  payments    Payment[]
  tickets     MaintenanceTicket[]
  activities  Activity[]
  messages    Message[]
  documents   Document[]
  invoices    Invoice[]
  auditLogs   AuditLog[]
  devices     Device[]
  vendors     Vendor[]
  inspections Inspection[]
  accounts    Account[]
  transactions Transaction[]
  insurancePolicies InsurancePolicy[]
  calendarEvents CalendarEvent[]
  listings    Listing[]
  applications Application[]
  tenantScreenings  TenantScreening[]
  notifications     Notification[]
  workflows         Workflow[]
  complianceRules   ComplianceRule[]
  complianceChecks  ComplianceCheck[]
  portalSettings    PortalSetting[]
  rentAdjustments   RentAdjustment[]
  utilityReadings   UtilityReading[]
  keyManagement     KeyManagement[]
  parkingSpots      ParkingSpot[]
  amenityBookings   AmenityBooking[]
  announcements     Announcement[]
  surveys           Survey[]
  surveyResponses   SurveyResponse[]
  emergencyContacts EmergencyContact[]
  leaseRenewals     LeaseRenewal[]
  lateFeeConfigs    LateFeeConfig[]
  paymentPlans      PaymentPlan[]
  smartDevices      SmartDevice[]
  visitors          Visitor[]
  packages          Package[]
  energyReadings    EnergyReading[]
  budgets           Budget[]
  moveInOuts        MoveInOut[]
  eSignatures       ESignature[]
  pets              Pet[]
  disputes          Dispute[]
  assets            Asset[]
  marketIntels      MarketIntel[]
  client      Client?  @relation(fields: [clientId], references: [id])
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  avatar        String?
  role          String   @default("member")
  phone         String?
  department    String?
  isActive      Boolean  @default(true)
  lastLogin     DateTime?
  mfaEnabled    Boolean  @default(false)
  mfaSecret     String?
  passwordHash  String?
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  activities    Activity[]
  sessions      Session[]
  auditLogs     AuditLog[]
  devices       Device[]
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  deviceId    String?
  token       String   @unique
  ipAddress   String?
  userAgent   String?
  isActive    Boolean  @default(true)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id])
  device      Device?  @relation(fields: [deviceId], references: [id])
}

model Device {
  id            String   @id @default(cuid())
  serialKey     String   @unique
  deviceName    String?
  deviceType    String   @default("desktop")
  os            String?
  browser       String?
  ipAddress     String?
  macAddress    String?
  status        String   @default("pending")
  activatedAt   DateTime?
  lastSeenAt    DateTime?
  workspaceId   String
  userId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  user          User?     @relation(fields: [userId], references: [id])
  sessions      Session[]
  licenseKeys   LicenseKey[]
}

model Client {
  id              String   @id @default(cuid())
  companyName     String
  contactName     String
  email           String   @unique
  phone           String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  country         String   @default("US")
  website         String?
  industry        String?
  companySize     String?
  taxId           String?
  status          String   @default("active")
  plan            String   @default("starter")
  billingCycle    String   @default("monthly")
  monthlyFee      Float    @default(0)
  setupFee        Float    @default(0)
  currency        String   @default("USD")
  discountPercent Float    @default(0)
  trialStart      DateTime?
  trialEnd        DateTime?
  contractStart   DateTime?
  contractEnd     DateTime?
  notes           String?
  logo            String?
  primaryColor    String?
  customDomain    String?
  maxProperties   Int      @default(10)
  maxUsers        Int      @default(5)
  maxDevices      Int      @default(3)
  features        String?
  databaseUrl     String?   // Full connection URL to the tenant's PostgreSQL database
  databaseName    String?   // Name of the tenant database (e.g., "tf_meridian")
  dbStatus        String    @default("pending") // pending, provisioning, active, error
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspaces      Workspace[]
  invoices        Invoice[]
  licenseKeys     LicenseKey[]
  auditLogs       AuditLog[]
  quotations      Quotation[]
}

model LicenseKey {
  id          String   @id @default(cuid())
  key         String   @unique
  type        String   @default("standard")
  plan        String   @default("starter")
  maxDevices  Int      @default(1)
  maxUsers    Int      @default(5)
  status      String   @default("available")
  activatedAt DateTime?
  expiresAt   DateTime?
  clientId    String
  deviceId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id])
  device      Device?  @relation(fields: [deviceId], references: [id])
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  clientId      String
  workspaceId   String?
  type          String   @default("subscription")
  status        String   @default("draft")
  issueDate     DateTime
  dueDate       DateTime
  paidDate      DateTime?
  subtotal      Float    @default(0)
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  discount      Float    @default(0)
  total         Float    @default(0)
  paidAmount    Float    @default(0)
  currency      String   @default("USD")
  notes         String?
  terms         String?
  items         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  client        Client    @relation(fields: [clientId], references: [id])
  workspace     Workspace? @relation(fields: [workspaceId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entity      String
  entityId    String?
  userId      String?
  workspaceId String
  clientId    String?
  ipAddress   String?
  userAgent   String?
  details     String?
  severity    String   @default("info")
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  client      Client?  @relation(fields: [clientId], references: [id])
}

model Property {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  type          String   @default("residential")
  address       String
  city          String
  state         String?
  zipCode       String?
  country       String   @default("US")
  lat           Float?
  lng           Float?
  description   String?
  totalUnits    Int      @default(0)
  occupiedUnits Int      @default(0)
  floors        Int?
  yearBuilt     Int?
  totalArea     Float?
  image         String?
  status        String   @default("active")
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  units         Unit[]
  leases        Lease[]
  tickets       MaintenanceTicket[]
  documents     Document[]
  inspections   Inspection[]
}

model Unit {
  id          String   @id @default(cuid())
  unitNumber  String
  propertyId  String
  floor       Int?
  type        String   @default("apartment")
  bedrooms    Int      @default(1)
  bathrooms   Int      @default(1)
  area        Float?
  rent        Float
  deposit     Float?
  status      String   @default("vacant")
  amenities   String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases      Lease[]
}

model Tenant {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String?
  avatar        String?
  type          String   @default("individual")
  company       String?
  idNumber      String?
  emergencyName String?
  emergencyPhone String?
  moveInDate    DateTime?
  moveOutDate   DateTime?
  status        String   @default("active")
  notes         String?
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  leases        Lease[]
  payments      Payment[]
  tickets       MaintenanceTicket[]
  messages      Message[]
  documents     Document[]
}

model Lease {
  id            String   @id @default(cuid())
  propertyId    String
  unitId        String
  tenantId      String
  startDate     DateTime
  endDate       DateTime
  monthlyRent   Float
  deposit       Float
  status        String   @default("active")
  type          String   @default("residential")
  terms         String?
  renewalDate   DateTime?
  rentEscalation Float?
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property      Property @relation(fields: [propertyId], references: [id])
  unit          Unit     @relation(fields: [unitId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  payments      Payment[]
}

model Payment {
  id          String   @id @default(cuid())
  leaseId     String
  tenantId    String
  amount      Float
  type        String   @default("rent")
  status      String   @default("pending")
  dueDate     DateTime
  paidDate    DateTime?
  method      String?
  reference   String?
  notes       String?
  lateFee     Float?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lease       Lease    @relation(fields: [leaseId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model MaintenanceTicket {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   @default("general")
  priority    String   @default("medium")
  status      String   @default("open")
  propertyId  String
  tenantId    String?
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  image       String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property    Property @relation(fields: [propertyId], references: [id])
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Activity {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String?
  userId      String?
  workspaceId String
  metadata    String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Message {
  id          String   @id @default(cuid())
  subject     String?
  content     String
  type        String   @default("email")
  direction   String   @default("outbound")
  status      String   @default("sent")
  tenantId    String?
  workspaceId String
  createdAt   DateTime @default(now())

  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("general")
  category    String?
  fileUrl     String?
  size        Int?
  propertyId  String?
  tenantId    String?
  workspaceId String
  createdAt   DateTime @default(now())

  property    Property? @relation(fields: [propertyId], references: [id])
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

// ── New World-Class Models ────────────────────────────────────────────────────

model Vendor {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  company       String?
  category      String   @default("general")
  specialty     String?
  licenseNumber String?
  insuranceExp  DateTime?
  rating        Float    @default(0)
  totalJobs     Int      @default(0)
  address       String?
  city          String?
  state         String?
  zipCode       String?
  taxId         String?
  paymentTerms  String   @default("net30")
  status        String   @default("active")
  notes         String?
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
}

model Inspection {
  id            String   @id @default(cuid())
  title         String
  type          String   @default("move_in")
  status        String   @default("scheduled")
  scheduledDate DateTime
  completedDate DateTime?
  propertyId    String
  unitId        String?
  inspectorName String?
  checklist     String?
  findings      String?
  rating        Float?
  photos        String?
  notes         String?
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
  property      Property  @relation(fields: [propertyId], references: [id])
}

model Account {
  id          String   @id @default(cuid())
  code        String
  name        String
  type        String   @default("asset")
  category    String?
  description String?
  parentCode  String?
  isActive    Boolean  @default(true)
  balance     Float    @default(0)
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Transaction {
  id          String   @id @default(cuid())
  date        DateTime
  description String
  amount      Float
  type        String   @default("debit")
  category    String?
  accountCode String
  reference   String?
  status      String   @default("posted")
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model InsurancePolicy {
  id            String   @id @default(cuid())
  policyNumber  String
  provider      String
  type          String   @default("property")
  premium       Float    @default(0)
  deductible    Float    @default(0)
  coverage      Float    @default(0)
  startDate     DateTime
  endDate       DateTime
  status        String   @default("active")
  propertyId    String?
  claims        String?
  notes         String?
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("event")
  startDate   DateTime
  endDate     DateTime?
  allDay      Boolean  @default(false)
  location    String?
  propertyId  String?
  tenantId    String?
  status      String   @default("confirmed")
  color       String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Listing {
  id            String   @id @default(cuid())
  title         String
  description   String?
  propertyId    String
  unitId        String?
  type          String   @default("rental")
  price         Float
  deposit       Float?
  status        String   @default("active")
  featured      Boolean  @default(false)
  amenities     String?
  photos        String?
  views         Int      @default(0)
  applications  Int      @default(0)
  listedDate    DateTime @default(now())
  availableFrom DateTime?
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
}

model Application {
  id            String   @id @default(cuid())
  listingId     String
  applicantName String
  email         String
  phone         String?
  income        Float?
  employment    String?
  moveInDate    DateTime?
  status        String   @default("submitted")
  score         Float?
  documents     String?
  notes         String?
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
}

// ── Enterprise Models ──────────────────────────────────────────────────────────

model TenantScreening {
  id              String   @id @default(cuid())
  tenantId        String
  type            String   @default("background") // background, credit, eviction, criminal
  status          String   @default("pending") // pending, in_progress, completed, failed
  provider        String? // screening provider name
  reportUrl       String? // link to full report
  creditScore     Int?
  criminalFound   Boolean  @default(false)
  evictionFound   Boolean  @default(false)
  riskLevel       String   @default("low") // low, medium, high
  submittedAt     DateTime?
  completedAt     DateTime?
  notes           String?
  workspaceId     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String?
  title       String
  message     String
  type        String   @default("info") // info, warning, error, success
  category    String   @default("general") // general, lease, payment, maintenance, system
  link        String? // deep link to related entity
  isRead      Boolean  @default(false)
  readAt      DateTime?
  sentVia     String   @default("in_app") // in_app, email, sms, push
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("lease_renewal") // lease_renewal, rent_reminder, move_in, move_out, inspection
  trigger     String   @default("manual") // manual, scheduled, event
  schedule    String? // cron expression for scheduled triggers
  isActive    Boolean  @default(true)
  priority    String   @default("medium") // low, medium, high
  steps       WorkflowStep[]
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model WorkflowStep {
  id           String   @id @default(cuid())
  workflowId   String
  stepOrder    Int
  name         String
  description  String?
  action       String // send_email, create_task, update_status, notify, delay
  config       String? // JSON string for action configuration
  assignTo     String? // user id or role
  delayMinutes Int      @default(0)
  status       String   @default("pending") // pending, active, completed, skipped, failed
  completedAt  DateTime?
  workspaceId  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workflow     Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model ComplianceRule {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     String   @default("legal") // legal, safety, health, housing, fair_housing
  jurisdiction String? // city, state, or federal level
  requirement  String? // description of the requirement
  frequency    String   @default("annual") // one_time, monthly, quarterly, annual
  isActive     Boolean  @default(true)
  penalty      String? // description of penalty for non-compliance
  reference    String? // legal reference or statute
  workspaceId  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace        Workspace        @relation(fields: [workspaceId], references: [id])
  complianceChecks ComplianceCheck[]
}

model ComplianceCheck {
  id            String   @id @default(cuid())
  ruleId        String
  propertyId    String?
  status        String   @default("pending") // pending, passed, failed, waived
  checkedBy     String? // user id
  checkedAt     DateTime?
  nextCheckDate DateTime?
  findings      String?
  documents     String? // JSON string of document references
  notes         String?
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  complianceRule ComplianceRule @relation(fields: [ruleId], references: [id])
  workspace      Workspace      @relation(fields: [workspaceId], references: [id])
}

model PortalSetting {
  id               String   @id @default(cuid())
  portalType       String   @default("tenant") // tenant, owner
  propertyId       String?
  allowPayments    Boolean  @default(true)
  allowMaintenance Boolean  @default(true)
  allowLeaseView   Boolean  @default(true)
  allowMessaging   Boolean  @default(true)
  allowDocuments   Boolean  @default(false)
  customWelcome    String? // custom welcome message
  brandColor       String?
  logoUrl          String?
  termsUrl         String?
  privacyUrl       String?
  supportEmail     String?
  supportPhone     String?
  isActive         Boolean  @default(true)
  workspaceId      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace        Workspace @relation(fields: [workspaceId], references: [id])
}

model RentAdjustment {
  id            String   @id @default(cuid())
  leaseId       String
  type          String   @default("increase") // increase, decrease, concession, promo
  amount        Float
  reason        String?
  effectiveDate DateTime
  endDate       DateTime?
  isPermanent   Boolean  @default(true)
  approvedBy    String? // user id
  status        String   @default("pending") // pending, approved, rejected, cancelled
  notes         String?
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
}

model UtilityReading {
  id               String   @id @default(cuid())
  propertyId       String
  unitId           String?
  utilityType      String   @default("electric") // electric, gas, water, sewer, trash, internet
  meterNumber      String?
  previousReading  Float?
  currentReading   Float
  consumption      Float    @default(0)
  unit             String   @default("kwh") // kwh, therms, gallons, cubic_feet
  readingDate      DateTime
  readBy           String? // user id or vendor
  imageUrl         String? // photo of meter
  notes            String?
  workspaceId      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace        Workspace @relation(fields: [workspaceId], references: [id])
}

model KeyManagement {
  id            String   @id @default(cuid())
  propertyId    String
  unitId        String?
  keyType       String   @default("physical") // physical, digital, fob, code
  label         String
  keyNumber     String?
  keyCode       String? // access code for digital locks
  holderName    String? // current holder
  holderContact String? // phone or email of holder
  issuedAt      DateTime?
  returnedAt    DateTime?
  status        String   @default("available") // available, issued, lost, damaged, disabled
  notes         String?
  workspaceId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace     Workspace @relation(fields: [workspaceId], references: [id])
}

model ParkingSpot {
  id           String   @id @default(cuid())
  propertyId   String
  spotNumber   String
  level        String? // floor or level
  type         String   @default("standard") // standard, compact, handicap, ev_charging, motorcycle
  vehicleLimit Int      @default(1)
  tenantId     String?
  leaseId      String?
  monthlyFee   Float    @default(0)
  status       String   @default("available") // available, occupied, reserved, maintenance, unavailable
  assignedAt   DateTime?
  notes        String?
  workspaceId  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspaceId], references: [id])
}

model AmenityBooking {
  id          String   @id @default(cuid())
  propertyId  String
  amenityName String // pool, gym, rooftop, laundry, conference_room, etc.
  tenantId    String?
  startTime   DateTime
  endTime     DateTime
  status      String   @default("confirmed") // confirmed, cancelled, completed, no_show
  notes       String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model Announcement {
  id              String   @id @default(cuid())
  propertyId      String?
